<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.memory-ingest</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/jared/openclaw/skills/memory-engine/scripts/live_ingest.sh</string>
        <string>--watch</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/jared/Projects/openclaw-memory</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>MEMORY_DB</key>
        <string>/Users/jared/Projects/openclaw-memory/memory.db</string>
        <key>HOME</key>
        <string>/Users/jared</string>
